{
  "name": "playground",
  "description": "A playground for the VSCode Testify extension",
  "version": "1.0.0",
  "author": "felixjb",
  "license": "MIT",
  "type": "module",
  "engineStrict": true,
  "engines": {
    "node": "^22.16.0",
    "npm": "^10.9.2"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --build",
    "test": "npm run test --workspaces --if-present",
    "start": "node ./packages/core/dist/main.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
